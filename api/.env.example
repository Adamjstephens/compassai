COMPASSAI_JWT_SECRET="same-secret-as-vercel"
ALLOWED_ORIGINS="http://localhost:3000"
COMPASSAI_FREE_HOSTING_MODE="true"
COMPASSAI_DATA_DIR="./.data"
MAX_FILE_MB="250"
MAX_DAILY_AUDIO_MINUTES_PER_USER="300"
MAX_CONCURRENT_JOBS_PER_USER="2"
RATE_LIMIT_PER_MINUTE="120"

# Local-only dev bypass. Never enable in production.
COMPASSAI_DEV_AUTH="false"
COMPASSAI_DEV_EMAIL="dev@convertros.com"
